# Copy to .env and adjust
PORT=3000
NODE_ENV=development

# Port 5433 matches backend/docker-compose.yml (5433 on host → 5432 in container).
# If you use a local Postgres on 5432 instead, point DATABASE_URL at that instance and create role/db.
DATABASE_URL=postgresql://greenquote:greenquote@127.0.0.1:5433/greenquote

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_SEC=604800
