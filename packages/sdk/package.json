{
  "name": "@greenquote/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "openapi-typescript ../../openapi/openapi.yaml -o src/generated/schema.d.ts",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.0"
  },
  "devDependencies": {
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.7.3"
  }
}
