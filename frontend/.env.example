# Required for Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string-in-production

# App URL (used by Auth.js)
AUTH_URL=http://localhost:3000

# Required: Nest API base URL including /api prefix (no trailing slash). Start the API first; `pnpm dev` checks /health.
API_URL=http://localhost:3001/api
